<script>
// ── STORAGE KEYS (must match kiosk files) ─────────────────────

const FORMS_KEY = 'kiosk_forms';
const PIN_KEY   = 'kiosk_pin';

const DEFAULT_FORMS = [
  { id:'1', name:'Patient Intake',          url:'https://docs.google.com/forms/d/e/PLACEHOLDER1/viewform' },
  { id:'2', name:'Medical History',         url:'https://docs.google.com/forms/d/e/PLACEHOLDER2/viewform' },
  { id:'3', name:'Consent & Authorization', url:'https://docs.google.com/forms/d/e/PLACEHOLDER3/viewform' },
  { id:'4', name:'Insurance Verification',  url:'https://docs.google.com/forms/d/e/PLACEHOLDER4/viewform' },
  { id:'5', name:'Follow-Up Questionnaire', url:'https://docs.google.com/forms/d/e/PLACEHOLDER5/viewform' },
];
const DEFAULT_PIN = '1234';

// ── STORAGE HELPERS ───────────────────────────────────────────

function getForms() {
  try { const s=localStorage.getItem(FORMS_KEY); return s?JSON.parse(s):DEFAULT_FORMS; } catch{return DEFAULT_FORMS;}
}
function writeForms(f) { localStorage.setItem(FORMS_KEY, JSON.stringify(f)); }
function getPin()  { return localStorage.getItem(PIN_KEY) || DEFAULT_PIN; }
function writePin(p) { localStorage.setItem(PIN_KEY, p); }
const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

// ── TOAST ─────────────────────────────────────────────────────

let toastTimer;
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2400);
}

// ── RENDER FORMS LIST ─────────────────────────────────────────

let editingId = null;

function renderForms() {
  const forms = getForms();
  const el = document.getElementById('form-list');
  document.getElementById('form-count').textContent = forms.length + ' form' + (forms.length===1?'':'s');

  if (!forms.length) {
    el.innerHTML = '<div class="empty-list">No forms yet — add one below.</div>';
    return;
  }

  el.innerHTML = forms.map((f, i) => {
    const isEditing = editingId === f.id;
    return `
    <div class="form-row${isEditing?' editing':''}" id="row-${f.id}">
      <div class="row-order">
        <button class="order-btn" onclick="moveForm('${f.id}',-1)" title="Move up"  ${i===0?'disabled':''}>▲</button>
        <button class="order-btn" onclick="moveForm('${f.id}',1)"  title="Move down" ${i===forms.length-1?'disabled':''}>▼</button>
      </div>
      <div class="row-fields">
        ${isEditing ? `
          <input class="row-input" id="edit-name-${f.id}" type="text" value="${esc(f.name)}" placeholder="Form name" />
          <input class="row-input" id="edit-url-${f.id}"  type="url"  value="${esc(f.url)}"  placeholder="Google Form URL" />
        ` : `
          <div class="row-name">${esc(f.name)}</div>
          <div class="row-url">${esc(f.url)}</div>
        `}
      </div>
      <div class="row-actions">
        ${isEditing ? `
          <button class="icon-btn save"   onclick="saveEdit('${f.id}')">✓ Save</button>
          <button class="icon-btn cancel" onclick="cancelEdit()">✕</button>
        ` : `
          <button class="icon-btn edit" onclick="startEdit('${f.id}')">✏ Edit</button>
          <button class="icon-btn del"  onclick="deleteForm('${f.id}')">🗑</button>
        `}
      </div>
    </div>`;
  }).join('');
}

// ── FORM CRUD ─────────────────────────────────────────────────

function addForm() {
  const name = document.getElementById('new-name').value.trim();
  const url  = document.getElementById('new-url').value.trim();
  if (!name) { toast('Please enter a form name.'); return; }
  if (!url)  { toast('Please enter a form URL.'); return; }
  const forms = getForms();
  forms.push({ id: Date.now().toString(), name, url });
  writeForms(forms);
  document.getElementById('new-name').value = '';
  document.getElementById('new-url').value  = '';
  editingId = null;
  renderForms();
  toast('Form added ✓');
}

function deleteForm(id) {
  if (!confirm('Delete this form from the kiosk?')) return;
  writeForms(getForms().filter(f=>f.id!==id));
  if (editingId===id) editingId=null;
  renderForms();
  toast('Form deleted.');
}

function startEdit(id) {
  editingId = id;
  renderForms();
  document.getElementById('edit-name-'+id)?.focus();
}

function cancelEdit() {
  editingId = null;
  renderForms();
}

function saveEdit(id) {
  const name = document.getElementById('edit-name-'+id)?.value.trim();
  const url  = document.getElementById('edit-url-'+id)?.value.trim();
  if (!name || !url) { toast('Name and URL are both required.'); return; }
  const forms = getForms().map(f => f.id===id ? { ...f, name, url } : f);
  writeForms(forms);
  editingId = null;
  renderForms();
  toast('Changes saved ✓');
}

function moveForm(id, dir) {
  const forms = getForms();
  const i = forms.findIndex(f=>f.id===id);
  const j = i + dir;
  if (j<0 || j>=forms.length) return;
  [forms[i], forms[j]] = [forms[j], forms[i]];
  writeForms(forms);
  renderForms();
}

// ── PIN ───────────────────────────────────────────────────────

function renderPin() {
  document.getElementById('cur-pin-display').textContent = getPin();
}

function savePin() {
  const v = document.getElementById('new-pin').value.trim();
  const msg = document.getElementById('pin-msg');
  if (!/^\d{4}$/.test(v)) {
    msg.className='field-msg err'; msg.textContent='PIN must be exactly 4 digits.'; return;
  }
  writePin(v);
  document.getElementById('new-pin').value = '';
  renderPin();
  msg.className='field-msg ok'; msg.textContent='PIN updated ✓';
  setTimeout(()=>msg.textContent='', 3000);
  toast('PIN saved ✓');
}

// ── EXPORT / IMPORT ───────────────────────────────────────────

function exportForms() {
  const json = JSON.stringify(getForms(), null, 2);
  const blob = new Blob([json], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'kiosk-forms.json';
  a.click();
  URL.revokeObjectURL(a.href);
  toast('Exported kiosk-forms.json');
}

function toggleImport() {
  const area   = document.getElementById('import-area');
  const btn    = document.getElementById('import-submit');
  const showing = area.style.display === 'block';
  area.style.display  = showing ? 'none' : 'block';
  btn.style.display   = showing ? 'none' : 'inline-block';
  if (!showing) area.focus();
}

function importForms() {
  const raw = document.getElementById('import-area').value.trim();
  const msg = document.getElementById('io-msg');
  try {
    const parsed = JSON.parse(raw);
    if (!Array.isArray(parsed)) throw new Error('Expected an array.');
    if (!parsed.every(f=>f.name&&f.url)) throw new Error('Each entry needs "name" and "url".');
    // Ensure IDs exist
    const fixed = parsed.map(f => ({ id: f.id || Date.now().toString()+Math.random(), name:f.name, url:f.url }));
    writeForms(fixed);
    editingId = null;
    renderForms();
    document.getElementById('import-area').value = '';
    toggleImport();
    msg.className='ok'; msg.textContent=`Imported ${fixed.length} form${fixed.length===1?'':'s'} ✓`;
    setTimeout(()=>msg.textContent='',4000);
    toast('Import successful ✓');
  } catch(e) {
    msg.className='err'; msg.textContent='Invalid JSON: '+e.message;
  }
}

function resetAll() {
  if (!confirm('Reset all forms to the default placeholder list? This cannot be undone.')) return;
  localStorage.removeItem(FORMS_KEY);
  editingId = null;
  renderForms();
  toast('Reset to defaults.');
}

// ── ORIGIN WARNING ────────────────────────────────────────────
// Show a soft notice if the page is running on file:// protocol,
// since some browsers isolate file:// pages differently.

if (location.protocol === 'file:') {
  document.getElementById('origin-notice').style.display = 'flex';
}

// ── KEYBOARD SHORTCUTS ────────────────────────────────────────

document.addEventListener('keydown', e => {
  if (e.key === 'Enter') {
    if (document.activeElement?.id === 'new-name' ||
        document.activeElement?.id === 'new-url') {
      addForm();
    }
  }
  if (e.key === 'Escape' && editingId) cancelEdit();
});

// ── INIT ──────────────────────────────────────────────────────

renderForms();
renderPin();
</script>
