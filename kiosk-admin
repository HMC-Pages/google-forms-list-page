<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kiosk Admin Panel</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<!--
  STANDALONE ADMIN PANEL
  Manages the form list and PIN for both kiosk files.
  Changes are saved to localStorage and will appear in the kiosk automatically.

⚠ IMPORTANT — SAME ORIGIN REQUIRED:
This file must be served from the same domain/host as the kiosk files
for localStorage to be shared. Options:
• All three files in the same GitHub Pages repo ✓
• All three on the same Netlify site ✓
• All opened as local files (file://) in the same browser ✓
• Different domains = data will NOT sync ✗
–>

<style>
:root {
  --bg:         #F0F4F8;
  --card:       #ffffff;
  --primary:    #0B5563;
  --primary-lt: #1A7A8A;
  --accent:     #D4EDF1;
  --text:       #1C2E35;
  --muted:      #607585;
  --border:     #D0DCE4;
  --danger:     #B03A2E;
  --danger-bg:  #FDECEA;
  --success:    #1A7A5E;
  --success-bg: #D6F5EC;
  --warn:       #8A6000;
  --warn-bg:    #FFF3CD;
  --shadow:     0 2px 16px rgba(11,85,99,.09);
  --r:          14px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Outfit', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
}

/* ── LAYOUT ───────────────────────────────────────────────── */

.topbar {
  background: var(--primary);
  color: white;
  padding: 22px 36px;
  display: flex;
  align-items: baseline;
  gap: 16px;
}
.topbar h1 {
  font-family: 'DM Serif Display', serif;
  font-size: 1.7rem;
  font-weight: 400;
}
.topbar-sub {
  font-size: .85rem;
  opacity: .65;
  font-weight: 300;
}

.page {
  max-width: 780px;
  margin: 0 auto;
  padding: 32px 24px 80px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

/* ── CARDS ────────────────────────────────────────────────── */

.card {
  background: var(--card);
  border-radius: var(--r);
  box-shadow: var(--shadow);
  overflow: hidden;
}

.card-header {
  padding: 18px 22px 14px;
  border-bottom: 2px solid var(--bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.card-header h2 {
  font-size: 1rem;
  font-weight: 600;
  color: var(--text);
}
.card-header-note {
  font-size: .78rem;
  color: var(--muted);
}

.card-body { padding: 20px 22px; }

/* ── NOTICES ──────────────────────────────────────────────── */

.notice {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  border-radius: 10px;
  padding: 13px 16px;
  font-size: .88rem;
  line-height: 1.5;
}
.notice.warn    { background: var(--warn-bg);    color: var(--warn);    border: 1px solid #f0d060; }
.notice.info    { background: var(--accent);     color: var(--primary); border: 1px solid #a5d8e6; }
.notice.success { background: var(--success-bg); color: var(--success); border: 1px solid #7adfc0; }
.notice.danger  { background: var(--danger-bg);  color: var(--danger);  border: 1px solid #f5b4ae; }
.notice-icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 1px; }

/* ── FORM LIST ────────────────────────────────────────────── */

#form-list { display: flex; flex-direction: column; gap: 8px; min-height: 40px; }

.form-row {
  background: var(--bg);
  border: 2px solid transparent;
  border-radius: 10px;
  padding: 12px 14px;
  display: flex;
  align-items: center;
  gap: 12px;
  transition: border-color .15s, background .15s;
}
.form-row.editing {
  background: #fff;
  border-color: var(--primary-lt);
  box-shadow: 0 0 0 3px rgba(26,122,138,.10);
}

.row-handle {
  color: #b0bec5;
  font-size: 1.1rem;
  cursor: grab;
  flex-shrink: 0;
  user-select: none;
  padding: 0 2px;
}

.row-order {
  display: flex;
  flex-direction: column;
  gap: 3px;
  flex-shrink: 0;
}
.order-btn {
  background: none;
  border: 1px solid var(--border);
  border-radius: 5px;
  width: 24px; height: 22px;
  cursor: pointer;
  font-size: .7rem;
  color: var(--muted);
  display: flex; align-items: center; justify-content: center;
  transition: background .1s, color .1s;
}
.order-btn:hover { background: var(--accent); color: var(--primary); border-color: var(--primary-lt); }
.order-btn:disabled { opacity: .3; cursor: default; }
.order-btn:disabled:hover { background: none; color: var(--muted); border-color: var(--border); }

.row-fields {
  flex: 1;
  min-width: 0;
}

/* Static view */
.row-name { font-weight: 500; font-size: .98rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.row-url  { font-size: .74rem; color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 2px; }

/* Inline edit inputs */
.row-input {
  width: 100%;
  border: 2px solid var(--border);
  border-radius: 8px;
  padding: 7px 10px;
  font-family: 'Outfit', sans-serif;
  font-size: .9rem;
  background: var(--bg);
  color: var(--text);
  margin-bottom: 6px;
  transition: border-color .15s;
}
.row-input:last-child { margin-bottom: 0; }
.row-input:focus { outline: none; border-color: var(--primary); background: white; }

.row-actions { display: flex; gap: 6px; flex-shrink: 0; }

.icon-btn {
  background: none;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: .85rem;
  cursor: pointer;
  color: var(--muted);
  white-space: nowrap;
  transition: all .15s;
  font-family: 'Outfit', sans-serif;
}
.icon-btn:hover { background: var(--bg); color: var(--text); }
.icon-btn.edit  { }
.icon-btn.save  { background: var(--primary); color: white; border-color: var(--primary); }
.icon-btn.save:hover { background: var(--primary-lt); }
.icon-btn.del   { color: var(--danger); border-color: #f5b4ae; }
.icon-btn.del:hover { background: var(--danger-bg); }
.icon-btn.cancel { }

.empty-list {
  text-align: center;
  padding: 28px 20px;
  color: var(--muted);
  font-size: .9rem;
  background: var(--bg);
  border-radius: 10px;
}

/* ── ADD FORM ─────────────────────────────────────────────── */

.add-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-top: 16px;
}
@media (max-width: 540px) { .add-row { grid-template-columns: 1fr; } }

.field {
  width: 100%;
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 11px 13px;
  font-family: 'Outfit', sans-serif;
  font-size: .95rem;
  background: white;
  color: var(--text);
  transition: border-color .15s;
}
.field:focus { outline: none; border-color: var(--primary); }
.field::placeholder { color: #b5c5cf; }

.add-row-btn {
  grid-column: 1 / -1;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 12px;
  font-family: 'Outfit', sans-serif;
  font-size: .95rem;
  font-weight: 500;
  cursor: pointer;
  transition: background .15s;
}
.add-row-btn:hover { background: var(--primary-lt); }

/* ── PIN ──────────────────────────────────────────────────── */

.pin-row { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
.pin-field-wrap { display: flex; flex-direction: column; gap: 5px; }
.field-label { font-size: .78rem; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .06em; }
.pin-in {
  width: 110px;
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 13px;
  font-family: 'Outfit', sans-serif;
  font-size: 1rem;
  letter-spacing: .15em;
  text-align: center;
  background: white;
  color: var(--text);
}
.pin-in:focus { outline: none; border-color: var(--primary); }

.btn-save-pin {
  background: var(--primary);
  color: white; border: none; border-radius: 10px;
  padding: 10px 22px;
  font-family: 'Outfit', sans-serif; font-size: .9rem; font-weight: 500;
  cursor: pointer; transition: background .15s; align-self: flex-end;
  margin-bottom: 1px;
}
.btn-save-pin:hover { background: var(--primary-lt); }

.pin-cur {
  font-size: .85rem; color: var(--muted);
  align-self: flex-end; margin-bottom: 13px;
}
strong.pin-val {
  font-weight: 600;
  color: var(--text);
  font-family: monospace;
  font-size: .95rem;
  letter-spacing: .1em;
}

.field-msg { font-size: .83rem; margin-top: 8px; min-height: 18px; }
.field-msg.ok  { color: var(--success); }
.field-msg.err { color: var(--danger); }

/* ── IMPORT / EXPORT ──────────────────────────────────────── */

.io-row { display: flex; gap: 10px; flex-wrap: wrap; }

.btn-outline {
  background: white;
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 20px;
  font-family: 'Outfit', sans-serif;
  font-size: .9rem;
  font-weight: 500;
  color: var(--text);
  cursor: pointer;
  transition: all .15s;
}
.btn-outline:hover { border-color: var(--primary); color: var(--primary); background: var(--accent); }

.btn-danger {
  background: white;
  border: 2px solid #f5b4ae;
  border-radius: 10px;
  padding: 10px 20px;
  font-family: 'Outfit', sans-serif;
  font-size: .9rem;
  font-weight: 500;
  color: var(--danger);
  cursor: pointer;
  transition: all .15s;
}
.btn-danger:hover { background: var(--danger-bg); border-color: var(--danger); }

.import-area {
  width: 100%;
  border: 2px solid var(--border);
  border-radius: 10px;
  padding: 10px 13px;
  font-family: monospace;
  font-size: .82rem;
  background: var(--bg);
  color: var(--text);
  resize: vertical;
  min-height: 80px;
  margin-top: 12px;
  transition: border-color .15s;
  display: none;
}
.import-area:focus { outline: none; border-color: var(--primary); }

.import-submit {
  margin-top: 8px;
  background: var(--primary); color: white; border: none; border-radius: 10px;
  padding: 9px 20px; font-family: 'Outfit', sans-serif; font-size: .88rem;
  font-weight: 500; cursor: pointer; display: none;
}
.import-submit:hover { background: var(--primary-lt); }

#io-msg { font-size: .83rem; margin-top: 8px; min-height: 18px; }
#io-msg.ok  { color: var(--success); }
#io-msg.err { color: var(--danger); }

/* ── TOAST ────────────────────────────────────────────────── */

#toast {
  position: fixed;
  bottom: 28px; left: 50%; transform: translateX(-50%) translateY(20px);
  background: #1C2E35;
  color: white;
  padding: 12px 24px;
  border-radius: 40px;
  font-size: .9rem;
  font-weight: 500;
  opacity: 0;
  transition: opacity .25s, transform .25s;
  pointer-events: none;
  white-space: nowrap;
  z-index: 100;
}
#toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>

</head>
